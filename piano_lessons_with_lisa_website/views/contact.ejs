  <!--Style Section-->
  <style>
  html, body {
    height: 100%;
    margin: 0;
    padding: 0;
    overflow-x: hidden;
  }

  body {
    background: linear-gradient(to bottom, #f8fafc, #eef2ff);
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    overflow-y: hidden;
  }

  /* Navbar */
  .navbar {
    background: rgba(255,255,255,0.85) !important;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    padding: 0.6rem 1rem;
  }

  .nav-link {
    transition: all 0.3s ease;
    padding: 0.35rem 0.6rem;
    font-size: 0.95rem;
  }

  .nav-link:hover {
    color: #4f46e5 !important;
    transform: translateY(-2px);
  }

  /* HERO */
  .hero {
    position: relative;
    height: 50vh;
    min-height: 320px;
    overflow: hidden;
  }

  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(60%);
  }

  .hero-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    text-align: center;
    padding: 0 1rem;
  }

  .hero-text h1 {
    font-size: 2.8rem;
    font-weight: 700;
    text-shadow: 0 10px 30px rgba(0,0,0,0.5);
    line-height: 1.05;
    margin: 0;
  }

  .hero-text p {
    font-size: 1rem;
    opacity: 0.9;
    margin-top: 0.5rem;
  }

  /* BUTTON */
  .btn-custom {
    background: #4f46e5;
    color: white;
    border-radius: 30px;
    padding: 10px 25px;
    transition: 0.3s;
  }

  .btn-custom:hover {
    background: #4338ca;
    transform: translateY(-3px);
  }

  /* SECTION */
  .section {
    padding: 24px 16px;
  }

  /* CARD */
  .info-card {
    background: white;
    border-radius: 20px;
    padding: 22px;
    box-shadow: 0 14px 30px rgba(0,0,0,0.08);
    transition: 0.3s;
  }

  .info-card:hover {
    transform: translateY(-3px);
  }

  /* VIDEO SECTION */
  .video-section {
    position: relative;
    height: 40vh;
    overflow: hidden;
  }

  .video-section video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(50%);
  }

  .video-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%);
    color: white;
    text-align: center;
  }

  /* Fade animation */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeIn 1s ease forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: 42vh;
    }

    .hero-text h1 {
      font-size: 2rem;
    }

    .hero-text p {
      font-size: 0.95rem;
    }

    .section {
      padding: 16px 12px;
    }

    .info-card {
      padding: 18px;
      border-radius: 16px;
      box-shadow: 0 10px 22px rgba(0,0,0,0.08);
    }

    .navbar {
      padding: 0.5rem 0.75rem;
    }

    .navbar-nav {
      flex-wrap: wrap;
      justify-content: center;
    }

    .nav-link {
      padding: 0.25rem 0.4rem;
      font-size: 0.9rem;
    }
  }
</style>

