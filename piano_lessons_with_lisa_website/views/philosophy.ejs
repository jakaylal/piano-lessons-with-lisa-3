  <style>

  body {
    background: linear-gradient(to bottom, #f8fafc, #eef2ff);
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    overflow-x: hidden;
    margin: 0;
  }

  /* Navbar */
  .navbar {
    background: rgba(255,255,255,0.85) !important;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    padding: 0.6rem 1rem;
    flex-shrink: 0;
  }

  .nav-link {
    transition: all 0.3s ease;
    padding: 0.35rem 0.6rem;
    font-size: 0.95rem;
  }

  .nav-link:hover {
    color: #4f46e5 !important;
    transform: translateY(-2px);
  }

  /* HERO */
  .hero {
    position: relative;
    height: 34vh;
    min-height: 180px;
    max-height: 240px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(60%);
  }

  .hero-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    text-align: center;
    padding: 0 1rem;
  }

  .hero-text h1 {
    font-size: 1.8rem;
    font-weight: 700;
    text-shadow: 0 10px 30px rgba(0,0,0,0.5);
    line-height: 1.05;
    margin: 0;
  }

  .hero-text p {
    font-size: 0.9rem;
    opacity: 0.9;
    margin-top: 0.4rem;
  }

  /* BUTTON */
  .btn-custom {
    background: #4f46e5;
    color: white;
    border-radius: 30px;
    padding: 10px 25px;
    transition: 0.3s;
  }

  .btn-custom:hover {
    background: #4338ca;
    transform: translateY(-3px);
  }

  /* SECTION */
  .section {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 10px 12px 10px;
  }

  /* CARD */
  .philosophy-card {
    background: white;
    border-radius: 18px;
    padding: 16px 18px;
    box-shadow: 0 14px 30px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    height: 100%;
  }

  .philosophy-card:hover {
    transform: translateY(-3px);
  }

  .philosophy-text {
    font-size: 0.9rem;
    line-height: 1.5;
    color: #475569;
    margin-bottom: 0.5rem;
  }

  .title {
    font-size: 1.45rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 8px;
  }

  .philosophy-grid {
    max-width: 1000px;
    width: 100%;
  }

  .site-footer {
    margin-top: 0;
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
  }

  /* Fade animation */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeIn 1s ease forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: 26vh;
      min-height: 150px;
    }

    .hero-text h1 {
      font-size: 2rem;
    }

    .hero-text p {
      font-size: 0.95rem;
    }

    .section {
      padding: 16px 12px;
    }

    .info-card {
      padding: 18px;
      border-radius: 16px;
      box-shadow: 0 10px 22px rgba(0,0,0,0.08);
    }

    .navbar {
      padding: 0.5rem 0.75rem;
    }

    .navbar-nav {
      flex-wrap: wrap;
      justify-content: center;
    }

    .nav-link {
      padding: 0.25rem 0.4rem;
      font-size: 0.9rem;
    }
  }
</style>

